supabase/

# Documentacao
*.md
docs/

# IDE e editor
.cursor/
.vscode/

# Logs e arquivos temporarios
*.log
bun.lockb

# Scripts de VPS - nao fazem parte do app
vps/

# Arquivos de teste
public/leads_teste.xlsx
src/test/

# Planos e configs do Claude
.claude/
